generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  expense
  income
  transfer
}

enum CategoryType {
  expense
  income
}

enum AccountType {
  cash
  card
  deposit
  credit
  investment
}

enum Currency {
  UAH
  USD
  EUR
}

enum AccountGroup {
  personal
  savings
  shared
}

model Account {
  id                String             @id @default(cuid())
  name              String
  type              AccountType
  currency          Currency
  balance           Decimal            @db.Decimal(14, 2)
  icon              String
  color             String
  group             AccountGroup
  transactions      Transaction[]
  recurringPayments RecurringPayment[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Category {
  id                String             @id @default(cuid())
  label             String
  type              CategoryType
  icon              String
  color             String
  gradientFrom      String
  gradientTo        String
  transactions      Transaction[]
  budgets           Budget[]
  recurringPayments RecurringPayment[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([label, type])
}

model Transaction {
  id            String          @id @default(cuid())
  name          String
  type          TransactionType
  amount        Decimal         @db.Decimal(14, 2)
  date          DateTime        @db.Date
  note          String?
  icon          String?
  currency      Currency
  accountId     String?
  account       Account?        @relation(fields: [accountId], references: [id], onDelete: SetNull)
  categoryId    String?
  category      Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryLabel String?
  tags          String[]        @default([])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([date])
  @@index([type])
  @@index([accountId])
  @@index([categoryId])
}

model Budget {
  id            String    @id @default(cuid())
  categoryId    String?
  category      Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryLabel String
  amount        Decimal   @db.Decimal(14, 2)
  alertAt       Int
  color         String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Goal {
  id        String   @id @default(cuid())
  title     String
  target    Decimal  @db.Decimal(14, 2)
  saved     Decimal  @db.Decimal(14, 2)
  deadline  DateTime @db.Date
  icon      String
  color     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RecurringPayment {
  id            String    @id @default(cuid())
  title         String
  amount        Decimal   @db.Decimal(14, 2)
  categoryId    String?
  category      Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryLabel String
  nextDate      DateTime  @db.Date
  frequency     String
  alertDays     Int
  icon          String
  accountId     String?
  account       Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
